     {%- comment -%} Check if shopify-review-left div exists and extract stars {%- endcomment -%}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Wait a moment for other scripts to load
    setTimeout(function() {
      var reviewDiv = document.querySelector('.shopify-review-left');
      if (reviewDiv) {
        var starsDiv = reviewDiv.querySelector('.stars');
        if (starsDiv) {
          // Create new div with just the stars
          var newStarsDiv = document.createElement('div');
          newStarsDiv.className = 'product-title-stars';
          newStarsDiv.innerHTML = starsDiv.innerHTML;
          
          // Insert it after the product title
          var productTitle = document.querySelector('.product_title');
          if (productTitle) {
            productTitle.parentNode.insertBefore(newStarsDiv, productTitle.nextSibling);
          }
        }
      }
    }, 500); // Wait 500ms for other elements to load
  });
</script>

<style>
  .product-title-stars {
    margin-top: 5px;
    margin-bottom: 15px;
    font-size: 30px;
    color: #ff5a49; /* Gold color for stars */
     line-height: 1em;
  }
</style>
