<!-- new really really simple reviews -->
{%- assign reviews = product.metafields.custom.really_really_simple_reviews.value -%}
{%- if reviews and reviews.size > 0 -%}
  {% assign total_stars = 0 %}
  {% assign count = reviews.size %}
  {% assign star_counts = "0,0,0,0,0" | split: "," %}

  {% for review in reviews %}
    {% assign total_stars = total_stars | plus: review.stars %}
    {% assign star_index = review.stars | minus: 1 %}
    {% assign current_count = star_counts[star_index] | plus: 1 %}
    {% assign star_counts[star_index] = current_count %}
  {% endfor %}

  {% assign avg_stars_float = total_stars | times: 1.0 | divided_by: count %}
  {% assign avg_stars = avg_stars_float | round: 1 %}

  <!-- Amazon-style Rating Breakdown -->
  <div class="amazon-rating-breakdown amzanewreview">
    <!-- Header -->
    <div class="rating-header">
      <div class="star-display">
        <div class="stars-background">★★★★★</div>
        <div class="stars-filled" style="width: {{ avg_stars | times: 20 }}%;">★★★★★</div>
      </div>
      <div class="rating-text">{{ avg_stars }} out of 5</div>
    </div>
    
    <div class="global-ratings">{{ count }} global ratings</div>

    <!-- Rating Bars -->
    {% for i in (5..1) %}
      {% assign array_index = i | minus: 1 %}
      {% assign star_count = star_counts[array_index] | default: 0 %}
      {% assign percentage = star_count | times: 100 | divided_by: count %}
      
      <div class="rating-bar-row">
        <div class="star-label">{{ i }} star</div>
        <div class="rating-bar-container">
          <div class="rating-bar-fill" style="width: {{ percentage }}%;"></div>
        </div>
        <div class="percentage-label">{{ percentage }}%</div>
      </div>
    {% endfor %}

    <!-- Hover Popup -->
    <div class="rating-popup">
      <div class="rating-popup-content">
        <h4>Rating Information</h4>
        <p>testing testing 123</p>
        <p>This breakdown shows how customers rated this product across all star levels.</p>
      </div>
      <div class="rating-popup-arrow"></div>
    </div>
  </div>

  <script>
    (function () {
  const alreadyInserted = () =>
    document.querySelector('.rating-popup-content .amazon-rating-breakdown');

  const tryInsert = () => {
    const source = document.querySelector('.really-review-div-class2 .amazon-rating-breakdown');
    const target = document.querySelector('.rating-popup-content');

    if (source && target && !alreadyInserted()) {
      target.innerHTML = '';
      target.appendChild(source.cloneNode(true));
      console.log('✅ Rating breakdown inserted');
    }
  };

  const observer = new MutationObserver(tryInsert);
  observer.observe(document.body, { childList: true, subtree: true });

  // Try once immediately too
  tryInsert();
})();

  </script>
{%- endif -%}
