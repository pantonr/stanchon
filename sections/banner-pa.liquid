<style>
.overlay,.overlay-banner-text{pointer-events:none;position:absolute}.banner-container{position:relative;width:100%;margin:0 auto;background-color:#000}.banner-container img{width:100%;height:auto;display:block}.overlay-banner-text{bottom:30px;left:30px;color:#fff;font-weight:700;font-size:7em;max-width:50%;line-height:.8em;text-shadow:0 2px 6px rgba(0,0,0,.5);z-index:2}.overlay{top:0;left:0;width:100%;height:100%}.beacon-wrapper{position:absolute;pointer-events:auto}.beacon{position:relative;width:60px;height:60px}.beacon div,.beacon::after,.beacon::before{position:absolute;top:50%;left:50%;border-radius:50%;transform:translate(-50%,-50%);content:''}.beacon::before{width:60px;height:60px;background-color:rgba(0,123,255,.2);animation:2s infinite pulse}.beacon::after{width:40px;height:40px;background-color:rgba(0,123,255,.4);animation:2s .5s infinite pulse}.beacon div{width:20px;height:20px;background-color:#007bff;z-index:2}@keyframes pulse{0%{transform:translate(-50%,-50%) scale(.8);opacity:.8}70%{transform:translate(-50%,-50%) scale(1.2);opacity:0}100%{transform:translate(-50%,-50%) scale(.8);opacity:0}}.popup{position:absolute;top:0;left:70px;width:220px;background:#fff;border:1px solid #ccc;border-radius:8px;padding:10px;box-shadow:0 2px 10px rgba(0,0,0,.2);opacity:0;pointer-events:none;transition:opacity .3s;z-index:1}.popup-left{left:auto;right:70px}.overlay-black-bar,.overlay-color-layer{position:absolute;left:0;width:100%;z-index:1;pointer-events:none}.popup h4{margin:0 0 5px;font-size:14px}.popup p{margin:0 0 8px;font-size:12px}.popup a{text-decoration:none;color:#00f;font-size:12px}.beacon-wrapper:hover .popup,.popup:hover{opacity:1;pointer-events:auto;z-index:3}.overlay-black-bar{bottom:0;background-color:#000;display:flex;align-items:center;justify-content:center;color:#fff;font-size:18px;font-weight:700}.overlay-color-layer{top:0;height:100%;background:radial-gradient(circle,rgba(0,0,0,0) 60%,rgba(0,0,0,.2) 100%)}@media screen and (max-width:775px){.beacon{display:none}.overlay-banner-text{font-size:3em;width:100%;min-width:100%;text-align:center}}@media screen and (max-width:1000px){.overlay-banner-text{font-size:5em;width:100%;min-width:100%;text-align:center}}.h4.mg__0{text-transform:uppercase}
</style>


