              <input type="number" id="panel-width" value="2" step="0.125" min="0.5" max="20" style="flex: 1; max-width: 80px; height: 32px; padding: 6px; border: 1px solid #ccc; border-radius: 3px; box-sizing: border-box;">
            </div>
